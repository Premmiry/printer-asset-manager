rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Companies Collection - สำคัญตรงนี้ครับ ต้องเป็น true เพื่อให้ดึงไปแสดงหน้า login ได้
    match /companies/{companyId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Departments Collection
    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Printers Collection
    match /printers/{printerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Printer Types Collection
    match /printerTypes/{typeId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Printer Brands Collection
    match /printerBrands/{brandId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
